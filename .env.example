# Copy this file to .env and set your OpenAI API key
OPENAI_API_KEY=sk-REDACTED

# (Optional) Anthropic / Claude API key
ANTHROPIC_API_KEY=claude-REDACTED

# (Optional) Google Gemini – used for chat and for "Recommend model"
GEMINI_API_KEY=redacted

# (Optional) xAI / Grok API key
XAI_API_KEY=redacted

# Spendline proxy (OpenAI-compatible base URL; tenant auth via x-spendline-key header)
SPENDLINE_URL=https://www.spendline.ai
SPENDLINE_API_KEY=ac_PASTE_KEY_HERE

# Optional dashboard attribution
# AGENT_ID=support-bot-v2
# CUSTOMER_ID=acme-corp
# COST_CENTER=engineering

